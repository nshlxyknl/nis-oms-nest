generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       Int      @id @default(autoincrement())
  password String
  username String   @unique
  role     UserRole @default(user)
}

model Employee {
  id          Int      @id @default(autoincrement())
  name        String
  email       String   @unique
  position    String
  department  String
  salary      Float?
  hireDate    DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Asset {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  category    String
  value       Float?
  location    String?
  status      AssetStatus @default(active)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Room {
  id          Int      @id @default(autoincrement())
  name        String
  capacity    Int
  location    String
  equipment   String?
  status      RoomStatus @default(available)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Notice {
  id          Int      @id @default(autoincrement())
  title       String
  content     String
  priority    NoticePriority @default(normal)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum UserRole {
  user
  admin
}

enum AssetStatus {
  active
  inactive
  maintenance
  disposed
}

enum RoomStatus {
  available
  occupied
  maintenance
}

enum NoticePriority {
  low
  normal
  high
  urgent
}
