generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       Int      @id @default(autoincrement())
  password String
  username String   @unique
  role     UserRole @default(user)
}

enum UserRole {
  user
  admin
}
